enable
configure terminal
hostname R1-INTERNAL
no ip domain-lookup
ip domain-name net2201.local
enable secret Net2201Enable!
username admin privilege 15 secret Net2201Admin!
service password-encryption
banner motd #Authorized access only.#

line console 0
 password Net2201Console!
 login
 logging synchronous
 exit
line vty 0 4
 transport input ssh
 login local
 exit
crypto key generate rsa modulus 1024
ip ssh version 2

interface gigabitEthernet0/0
 description TRUNK_TO_SW1_G0/1
 no shutdown
 exit
interface gigabitEthernet0/0.10
 description VLAN10_STAFF_ADMIN_GATEWAY
 encapsulation dot1Q 10
 ip address 192.168.10.1 255.255.255.0
 exit
interface gigabitEthernet0/0.20
 description VLAN20_STUDENT_USER_GATEWAY
 encapsulation dot1Q 20
 ip address 192.168.20.1 255.255.255.0
 exit
interface gigabitEthernet0/0.30
 description VLAN30_GUEST_PUBLIC_GATEWAY
 encapsulation dot1Q 30
 ip address 192.168.30.1 255.255.255.0
 exit
interface gigabitEthernet0/0.99
 description VLAN99_MANAGEMENT_GATEWAY
 encapsulation dot1Q 99
 ip address 192.168.99.1 255.255.255.0
 exit
interface gigabitEthernet0/0.999
 description NATIVE_UNUSED_VLAN_NO_IP
 encapsulation dot1Q 999 native
 no ip address
 exit

interface gigabitEthernet0/1
 description WAN_TO_R2_ISP_G0/0
 ip address 203.0.113.1 255.255.255.252
 no shutdown
 exit

ip dhcp excluded-address 192.168.10.1 192.168.10.20
ip dhcp excluded-address 192.168.20.1 192.168.20.20
ip dhcp excluded-address 192.168.30.1 192.168.30.20
ip dhcp excluded-address 192.168.99.1 192.168.99.30

ip dhcp pool VLAN10_STAFF
 network 192.168.10.0 255.255.255.0
 default-router 192.168.10.1
 dns-server 8.8.8.8
 exit
ip dhcp pool VLAN20_STUDENT
 network 192.168.20.0 255.255.255.0
 default-router 192.168.20.1
 dns-server 8.8.8.8
 exit
ip dhcp pool VLAN30_GUEST
 network 192.168.30.0 255.255.255.0
 default-router 192.168.30.1
 dns-server 8.8.8.8
 exit
ip dhcp pool VLAN99_MGMT
 network 192.168.99.0 255.255.255.0
 default-router 192.168.99.1
 dns-server 8.8.8.8
 exit

ip route 0.0.0.0 0.0.0.0 203.0.113.2

end
copy running-config startup-config
